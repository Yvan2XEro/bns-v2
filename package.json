{
	"name": "bns-repo",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"clean": "rimraf -g ./**/node_modules",
		"check": "biome check --write .",
		"check-types": "turbo run check-types",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.8",
		"@types/bun": "latest",
		"husky": "^9.1.7",
		"rimraf": "^6.1.3",
		"turbo": "^2.8.14",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"packageManager": "bun@1.3.10"
}
