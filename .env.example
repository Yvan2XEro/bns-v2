# MongoDB
MONGO_IMAGE=mongo:7
MONGO_USER=bns
MONGO_PASSWORD=changeme
MONGO_DB=bns

# Redis
REDIS_PASSWORD=changeme

# Meilisearch
MEILI_MASTER_KEY=changeme-master-key
MEILI_ENV=production

# Payload CMS (API)
PAYLOAD_SECRET=changeme-payload-secret
PAYLOAD_ALLOWED_ORIGINS=https://buynsellem.com,https://www.buynsellem.com

# Novu (notifications)
NOVU_SECRET_KEY=your-novu-secret-key
NOVU_APPLICATION_IDENTIFIER=your-novu-app-id

# Web frontend
CHAT_PUBLIC_URL=https://chat.buynsellem.com

# Mongo Express (DB admin UI)
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=changeme

# CORS for chat-service
CORS_ORIGIN=https://buynsellem.com,https://www.buynsellem.com

# GitHub repo (for prod images)
GITHUB_REPO=your-org/bns-repo

# --- For local / test network (no TLS) ---
# Use: docker compose -f docker-compose.yml -f docker-compose.local.yml up -d
# And override these values in your .env:
#NEXT_PUBLIC_API_URL=http://api.buynsellem.com
#CHAT_PUBLIC_URL=http://chat.buynsellem.com
#PAYLOAD_ALLOWED_ORIGINS=http://buynsellem.com,http://www.buynsellem.com
#CORS_ORIGIN=http://buynsellem.com,http://www.buynsellem.com
